PROJECT_NAME=mirza-bot
DOMAIN=bot.example.com
PORT=8000

DEBUG=0
MONGO_URI=mongodb://mongo:27017/
REDIS_URI=redis://redis:6379

CORS_ORIGINS='["https://bot.example.com"]'
JWT_CONFIG='{"jwks_url":"https://usso.example.com/.well-known/jwks.json"}'

USSO_BASE_URL=https://usso.example.com
USSO_NAMESPACE=ai
USSO_API_KEY=
ADMIN_CHAT_ID=

AI_TOOLKIT_BASE_URL=https://toolkit.example.com/api/ai/v1
AI_API_KEY=

MEDIA_BASE_URL=https://media.example.com/api/media/v1
MEDIA_API_KEY=
VIEWER_BASE_URL=https://view.example.com

SHOP_BASE_URL=https://shop.example.com/api/shop/v1
SAAS_BASE_URL=https://saas.example.com/api/saas/v1

TELEGRAM_TOKEN=
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
BALE_BOT_TOKEN=
BALE_BOT_NAME=

# Bale always uses getUpdates polling. Interval is sleep between long-poll cycles.
POLLING_INTERVAL_SECONDS=2

# Optional UX overrides (omit to use module defaults, e.g. billing DEFAULT_PRODUCTS_PER_PAGE=10)
# PRODUCTS_PER_PAGE=10
